          "name": "Exasol Demo DB"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=CREATE OR REPLACE TABLE \"{{ $json.DEMO_SCHEMA }}\".N8N_DEMO_CONTACTS (ID DECIMAL(9,0) PRIMARY KEY, FULL_NAME VARCHAR(200), EMAIL VARCHAR(320), STATUS VARCHAR(20), SIGNUP_DATE DATE, UPDATED_AT TIMESTAMP)",
        "restrictToSelect": false,
        "executionMode": "sequentially"
      },
      "id": "d3000000-0000-4000-8000-000000000003",
      "name": "Recreate Contacts Table",
      "type": "n8n-nodes-exasol.exasol",
      "typeVersion": 1,
      "position": [
        600,
        0
      ],
      "credentials": {
        "exasolApi": {
          "id": "ExasolDemoDbCred",
          "name": "Exasol Demo DB"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "jsCode": "// Seed data for the demo. Keys are UPPERCASE because the Exasol node\n// quotes identifiers and Exasol stores unquoted names in uppercase.\nreturn [\n  { json: { ID: 1, FULL_NAME: 'Ada Lovelace', EMAIL: 'ada@example.com', STATUS: 'new', SIGNUP_DATE: '2026-07-01' } },\n  { json: { ID: 2, FULL_NAME: 'Grace Hopper', EMAIL: 'grace@example.com', STATUS: 'new', SIGNUP_DATE: '2026-07-05' } },\n  { json: { ID: 3, FULL_NAME: 'Alan Turing', EMAIL: 'alan@invalid', STATUS: 'new', SIGNUP_DATE: '2026-07-10' } },\n];"
      },
      "id": "d3000000-0000-4000-8000-000000000004",
      "name": "Seed Contacts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        0
      ]
    },
    {
      "parameters": {
        "operation": "insert",
        "schema": "={{ $('Resolve Write Schema').first().json.DEMO_SCHEMA }}",
        "table": "N8N_DEMO_CONTACTS",
        "dataMode": "autoMapInputData"
      },
      "id": "d3000000-0000-4000-8000-000000000005",
      "name": "Insert Contacts",
      "type": "n8n-nodes-exasol.exasol",
      "typeVersion": 1,
      "position": [
        1200,
        0
      ],
      "credentials": {
        "exasolApi": {
          "id": "ExasolDemoDbCred",
          "name": "Exasol Demo DB"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "operation": "update",
        "schema": "={{ $('Resolve Write Schema').first().json.DEMO_SCHEMA }}",
        "table": "N8N_DEMO_CONTACTS",
        "dataMode": "defineBelow",
        "columns": {
          "mappings": [
            {
              "column": "STATUS",
              "value": "active"
            },
            {
              "column": "UPDATED_AT",
