          "id": "ExasolDemoDbCred",
          "name": "Exasol Demo DB"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "operation": "delete",
        "schema": "={{ $('Resolve Write Schema').first().json.DEMO_SCHEMA }}",
        "table": "N8N_DEMO_CONTACTS",
        "combineConditions": "AND",
        "where": {
          "conditions": [
            {
              "column": "STATUS",
              "operator": "equals",
              "value": "new"
            }
          ]
