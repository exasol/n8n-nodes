{
  "id": "ExaDemo01Flights",
  "name": "Exasol Demo 1 — Flight Delay Report",
  "active": false,
  "nodes": [
    {
      "parameters": {},
      "id": "d1000000-0000-4000-8000-000000000001",
      "name": "When clicking 'Execute workflow'",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        0,
