          "id": "ExasolDemoDbCred",
          "name": "Exasol Demo DB"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=CREATE TABLE IF NOT EXISTS \"{{ $json.DEMO_SCHEMA }}\".N8N_DEMO_DAILY_REVENUE (SALES_DATE DATE PRIMARY KEY, TRANSACTIONS DECIMAL(18,0), REVENUE DECIMAL(18,2))",
        "restrictToSelect": false,
        "executionMode": "sequentially"
      },
      "id": "d2000000-0000-4000-8000-000000000003",
      "name": "Create Mart Table",
      "type": "n8n-nodes-exasol.exasol",
      "typeVersion": 1,
      "position": [
        600,
        0
      ],
      "credentials": {
        "exasolApi": {
          "id": "ExasolDemoDbCred",
          "name": "Exasol Demo DB"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT SALES_DATE, COUNT(*) AS TRANSACTIONS, ROUND(SUM(PRICE), 2) AS REVENUE FROM RETAIL.SALES GROUP BY SALES_DATE ORDER BY SALES_DATE DESC LIMIT 14",
        "restrictToSelect": true,
        "executionMode": "sequentially"
      },
      "id": "d2000000-0000-4000-8000-000000000004",
      "name": "Aggregate Daily Revenue",
      "type": "n8n-nodes-exasol.exasol",
