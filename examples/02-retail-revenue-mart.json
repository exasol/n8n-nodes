      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "operation": "selectRows",
        "schema": "={{ $('Resolve Write Schema').first().json.DEMO_SCHEMA }}",
        "table": "N8N_DEMO_DAILY_REVENUE",
        "returnAll": true,
        "combineConditions": "AND",
        "where": {
          "conditions": [
            {
