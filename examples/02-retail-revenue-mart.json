          "id": "ExasolDemoDbCred",
          "name": "Exasol Demo DB"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "operation": "upsert",
        "schema": "={{ $('Resolve Write Schema').first().json.DEMO_SCHEMA }}",
        "table": "N8N_DEMO_DAILY_REVENUE",
